  m_Script: {fileID: 11500000, guid: 7da63d5e703fc46439ffa8db24674923, type: 3}
  m_Name: Day1_Client 3
  m_EditorClassIdentifier: Assembly-CSharp::PhoneCallData
  clientLine: 
  useClientLineParts: 1
  clientLineParts:
  - "\u0412\u0430\u043C \u043D\u0435 \u043D\u0443\u0436\u043D\u043E \u043D\u0438\u0447\u0435\u0433\u043E
    \u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C."
  - "\u041C\u044B \u0438\u0441\u043A\u043B\u044E\u0447\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0441 \u0434\u0435\u043B\u043E\u0432\u044B\u043C \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435\u043C\u2026
    \u041F\u043E\u0437\u0432\u043E\u043B\u044C\u0442\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u044C\u0441\u044F:
    \u044F \u043D\u0435 \u043A\u043B\u0438\u0435\u043D\u0442. \u042F \u2014 \u0447\u0435\u043B\u043E\u0432\u0435\u043A,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0432\u0438\u0434\u0438\u0442 \u0432\u0430\u0448
    \u043F\u043E\u0442\u0435\u043D\u0446\u0438\u0430\u043B."
  - "\u0412\u044B, \u043D\u0430\u0432\u0435\u0440\u043D\u043E\u0435, \u0441\u043B\u044B\u0448\u0430\u043B\u0438
    \u043E \u0432\u043E\u043B\u043D\u0435\u043D\u0438\u044F\u0445 \u0432 \u0433\u043E\u0440\u043E\u0434\u0435.
    \u041D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u043D\u0435\u0434\u043E\u0431\u0440\u043E\u0436\u0435\u043B\u0430\u0442\u0435\u043B\u0438
    \u043D\u0430\u0437\u044B\u0432\u0430\u044E\u0442 \u043D\u0430\u0441 \u0441\u0435\u043A\u0442\u043E\u0439?
    \u042D\u0442\u043E \u043D\u0435 \u0442\u0430\u043A."
  - "\u041C\u044B \u2014 \u0433\u0440\u0443\u043F\u043F\u0430 \u043B\u044E\u0434\u0435\u0439,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0445\u043E\u0442\u044F\u0442 \u0432\u0435\u0440\u043D\u0443\u0442\u044C
    \u0432\u0441\u0435\u043C \u0442\u043E, \u0447\u0442\u043E \u0443 \u043D\u0438\u0445
    \u043E\u0442\u043D\u044F\u043B\u0438\u2026 \u0422\u0438\u0448\u0438\u043D\u0443.
    \u0412\u043E\u0437\u043C\u043E\u0436\u043D\u043E\u0441\u0442\u044C \u0441\u043B\u044B\u0448\u0430\u0442\u044C
    \u043D\u0435 \u0442\u043E\u043B\u044C\u043A\u043E \u0448\u0443\u043C, \u043D\u043E
    \u0438 \u0442\u043E, \u0447\u0442\u043E \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0432\u0430\u0436\u043D\u043E."
  - "\u041C\u044B \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0438
    \u0442\u0435\u0445\u043D\u043E\u043B\u043E\u0433\u0438\u044E, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043F\u043E\u043C\u043E\u0433\u0430\u0435\u0442 \u043B\u044E\u0434\u044F\u043C
    \u043E\u0447\u0438\u0441\u0442\u0438\u0442\u044C \u0441\u043E\u0437\u043D\u0430\u043D\u0438\u0435
    \u043E\u0442 \u0442\u0440\u0435\u0432\u043E\u0433, \u0441\u0442\u0440\u0430\u0445\u043E\u0432,
    \u043D\u0430\u0432\u044F\u0437\u0430\u043D\u043D\u044B\u0445 \u043C\u044B\u0441\u043B\u0435\u0439.
    \u042D\u0442\u043E \u043D\u0435 \u043C\u0438\u0444\u0438\u0447\u0435\u0441\u043A\u0438\u0439
    \u0411\u043E\u0433. \u042D\u0442\u043E \u0442\u043E, \u0447\u0442\u043E \u0434\u043E\u043A\u0430\u0437\u0430\u043D\u043E
    \u043D\u0430\u0443\u043A\u043E\u0439. \u041C\u044B \u0445\u043E\u0442\u0438\u043C
    \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u0447\u0430\u0442\u044C \u0441
    \u0432\u0430\u0448\u0438\u043C \u0446\u0435\u043D\u0442\u0440\u043E\u043C."
