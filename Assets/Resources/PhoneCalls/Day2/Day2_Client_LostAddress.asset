  clientLineParts:
  - "\u0410\u043B\u043B\u043E, \u0434\u0430, \u0443 \u0432\u0430\u0441 \u0435\u0441\u0442\u044C
    \u0431\u0430\u0432\u0430\u0440\u0441\u043A\u0430\u044F?"
  - "\u0412\u043E\u0442 \u0435\u0451. \u041F\u043E\u0442\u043E\u043C \u043C\u043D\u0435
    \u043D\u0443\u0436\u043D\u0430, \u0437\u043D\u0430\u0435\u0442\u0435, \u0441
    \u0432\u0435\u0442\u0447\u0438\u043D\u043E\u0439, \u043D\u043E \u044F \u0432\u0435\u0433\u0435\u0442\u0430\u0440\u0438\u0430\u043D\u0435\u0446,
    \u043F\u043E\u044D\u0442\u043E\u043C\u0443 \u0431\u0435\u0437 \u043A\u043E\u043B\u0431\u0430\u0441\u044B
    \u0438 \u043C\u043E\u043B\u043E\u0447\u043A\u0438."
  - "\u0423 \u0432\u0430\u0441 \u0431\u043E\u0440\u0442\u0438\u043A\u0438 \u0441
    \u043D\u0430\u0447\u0438\u043D\u043A\u043E\u0439 \u0438\u043B\u0438 \u043D\u0435\u0442?\u041B\u0430\u043D
    \u0434\u0430\u0432\u0430\u0439\u0442\u0435 \u0431\u0435\u0437 \u0431\u043E\u0440\u0442\u0438\u043A\u043E\u0432
    \u0432\u043E\u043E\u0431\u0449\u0435."
  - "\u0415\u0449\u0451 \u0445\u043E\u0447\u0443 \u043F\u0430\u0441\u0442\u0443 \u0431\u043E\u043B\u043E\u043D\u044C\u0435\u0437\u0435,
    \u043D\u043E \u043C\u0430\u043A\u0430\u0440\u043E\u043D\u044B \u0437\u0430\u043C\u0435\u043D\u0438\u0442\u0435
    \u043D\u0430 \u043A\u0430\u0440\u0442\u043E\u0448\u043A\u0443."
  - "\u041D\u0443 \u0438 \u0434\u0432\u0435 \u043A\u043E\u043B\u044B, \u043D\u043E
    \u0431\u0435\u0437 \u043A\u043E\u0444\u0435\u0438\u043D\u0430. \u041E\u043D\u0430
