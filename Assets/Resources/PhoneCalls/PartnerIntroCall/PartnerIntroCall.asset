  m_Script: {fileID: 11500000, guid: 7da63d5e703fc46439ffa8db24674923, type: 3}
  m_Name: PartnerIntroCall
  m_EditorClassIdentifier: Assembly-CSharp::PhoneCallData
  clientLine: '

'
  useClientLineParts: 1
  clientLineParts:
  - "\u2014 \u0417\u0434\u0440\u0430\u0432\u0441\u0442\u0432\u0443\u0439\u0442\u0435,
    \u0412\u044B \u043F\u043E\u0437\u0432\u043E\u043D\u0438\u043B\u0438 \u0432 \u0442\u0435\u043B\u0435\u0444\u043E\u043D
    \u043F\u0441\u0438\u0445\u043E\u043B\u043E\u0433\u0438\u0447\u0435\u0441\u043A\u043E\u0439
    \u043F\u043E\u0434\u0434\u0435\u0440\u0436\u043A\u0438, \u0447\u0435\u043C \u043C\u043E\u0433\u0443\u2026
    \u041F\u043E\u0433\u043E\u0434\u0438, \u044D\u0442\u043E \u0436 \u044F \u0442\u0435\u0431\u0435
    \u0437\u0432\u043E\u043D\u044E, \u0445\u0430! \u041F\u0440\u043E\u0448\u043B\u044B\u0439
    \u043D\u0430\u043F\u0430\u0440\u043D\u0438\u043A \u0442\u0430\u043A\u0438\u043C
    \u0437\u0430\u043D\u0443\u0434\u043E\u0439 \u0431\u044B\u043B, \u043E\u043D \u043F\u043E\u0441\u0442\u043E\u044F\u043D\u043D\u043E
    \u0437\u0430 \u043F\u0440\u0430\u0432\u0438\u043B\u0430 \u0442\u0440\u044F\u0441\u0441\u044F\u2026
    \u0422\u044B \u0436 \u043D\u0435 \u0442\u0430\u043A\u043E\u0439? \u0421 \u043A\u043E\u043B\u043B\u0435\u043A\u0442\u0438\u0432\u043E\u043C
    \u043D\u0430\u0434\u043E \u0434\u0440\u0443\u0436\u0438\u0442\u044C\u2026"
  - "\u0410 \u0434\u0430, \u0443\u0441\u043B\u043E\u0432\u0438\u044F \u0440\u0430\u0431\u043E\u0442\u044B!
    \u0422\u044B \u0442\u0443\u0445\u043D\u0435\u0448\u044C \u0432 \u044D\u0442\u043E\u043C
    \u043E\u0444\u0438\u0441\u0435 \u0432\u0435\u0441\u044C \u0434\u0435\u043D\u044C,
    \u044F \u043F\u043E\u0434\u043C\u0435\u043D\u044F\u044E \u0442\u0435\u0431\u044F
    \u043D\u043E\u0447\u044C\u044E. \u041D\u0430 \u044D\u0442\u0438 \u0442\u0435\u043B\u0435\u0444\u043E\u043D\u044B
    \u0431\u0443\u0434\u0443\u0442 \u0437\u0432\u043E\u043D\u0438\u0442\u044C. \u0423
    \u043D\u0430\u0441 \u0438\u0445 \u0447\u0435\u0442\u044B\u0440\u0435, \u0445\u043E\u0442\u044C
    \u0447\u0442\u043E \u044F, \u0447\u0442\u043E \u0442\u044B \u2014 \u043E\u0434\u043D\u0438
    \u043D\u0430 \u0441\u043C\u0435\u043D\u0435. \u042D\u043A\u043E\u043D\u043E\u043C\u044F\u0442,
    \u0433\u0430\u0434\u044B"
  - "\u041D\u0430\u043C \u0437\u0432\u043E\u043D\u044F\u0442 \u0442\u043E\u043D\u043A\u0438\u0435
    \u0434\u0443\u0448\u0435\u0432\u043D\u044B\u0435 \u043E\u0440\u0433\u0430\u043D\u0438\u0437\u0430\u0446\u0438\u0438,
    \u0442\u0443\u0442 \u043D\u0443\u0436\u043D\u043E \u043F\u043E\u0434\u0431\u0438\u0440\u0430\u0442\u044C
    \u043A\u0430\u0436\u0434\u043E\u0435 \u0441\u043B\u043E\u0432\u043E. \u0425\u043E\u0442\u044F
    \u0442\u044B \u043D\u0435 \u043E\u0441\u043E\u0431\u043E \u0440\u0430\u0437\u0433\u043E\u0432\u043E\u0440\u0447\u0438\u0432\u044B\u0439.
    \u041D\u0438 \u043E\u0434\u043D\u043E\u0433\u043E \u0441\u043B\u043E\u0432\u0430
    \u043F\u043E\u043A\u0430 \u043D\u0435 \u0441\u043A\u0430\u0437\u0430\u043B, \u0445\u0430!
    \u041D\u0443 \u043F\u043E\u043A\u0430\u0436\u0438 \u0445\u043E\u0442\u044C, \u0447\u0442\u043E
    \u0443\u043C\u0435\u0435\u0448\u044C. \u041F\u043E\u043F\u0440\u043E\u0431\u0443\u0439
    \u0441\u043E\u0431\u0440\u0430\u0442\u044C \u043F\u0440\u0435\u0434\u043B\u043E\u0436\u0435\u043D\u0438\u0435"
