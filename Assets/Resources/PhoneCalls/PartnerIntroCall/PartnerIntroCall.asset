    callerReaction: "\u041D\u0443 \u0432\u043E\u0442. \u041D\u0438\u0447\u0435\u0433\u043E
      \u0442\u0430\u043A\u043E\u0433\u043E, \u0438 \u0442\u0443\u043F\u043E\u0439
      \u0441\u043F\u0440\u0430\u0432\u0438\u0442\u0441\u044F. \u041B\u0430\u0434\u043D\u043E,
      \u044F \u043E\u0442\u0441\u044B\u043F\u0430\u0442\u044C\u0441\u044F, \u0442\u044B
      \u0438 \u0442\u0430\u043A \u043C\u0435\u043D\u044F \u0437\u0430\u0434\u0435\u0440\u0436\u0430\u043B,
      \u0431\u044B\u0432\u0430\u0439!"
  - answerName: "\u041F\u043B\u043E\u0445\u043E\u0439 \u043E\u0442\u0432\u0435\u0442"
