    callerMoodDelta: 10
    sectInfluenceDelta: -5
    callerReaction: "\u0412\u043E\u0442 \u0438 \u044F \u0442\u0430\u043A\u0436\u0435
      \u0434\u0443\u043C\u0430\u044E! \u0415\u0441\u043B\u0438 \u043D\u0435 \u043F\u0440\u043E\u0444\u0435\u0441\u0441\u0438\u043E\u043D\u0430\u043B\u044C\u043D\u044B\u0439
