      \u0441\u0435\u0441\u0442\u044C? \u041B\u044E\u0434\u044F\u043C \u043F\u043E\u043C\u043E\u0433\u0430\u0442\u044C\u2026
      \u041C\u043E\u0436\u0435\u0442 \u0432 \u0442\u0440\u0435\u043D\u0435\u0440\u0430
      \u043F\u043E\u0439\u0442\u0438\u2026 \u042D\u0442\u043E \u0436\u0435 \u0442\u043E\u0436\u0435
