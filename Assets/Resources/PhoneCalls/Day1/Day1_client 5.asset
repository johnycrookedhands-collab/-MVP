    callerMoodDelta: -10
    sectInfluenceDelta: 5
    callerReaction: "\u0412 \u0441\u043C\u044B\u0441\u043B\u0435? \u0422\u044B \u0432\u043E\u043E\u0431\u0449\u0435
      \u043D\u0435 \u0447\u0443\u0432\u0441\u0442\u0432\u0443\u0435\u0448\u044C \u0441\u0443\u0442\u044C.
