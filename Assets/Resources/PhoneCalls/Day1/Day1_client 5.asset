      \u0432 \u043F\u0440\u043E\u0448\u043B\u0443\u044E \u0444\u043E\u0440\u043C\u0443...
      \u041C\u043E\u0436\u0435\u0442 \u043F\u043E\u043F\u0440\u043E\u0431\u043E\u0432\u0430\u0442\u044C
      \u0441\u0442\u0435\u0440\u043E\u0438\u0434\u044B\u2026 \u042F \u0441\u043B\u044B\u0448\u0430\u043B\u0430
      \u0410\u043D\u0434\u0440\u0435 \u0410\u0433\u0430\u0441\u0441\u0438\u2026 \u0412
      \u043E\u0431\u0449\u0435\u043C, \u043F\u0430\u0441\u0438\u0431, \u0440\u0430\u0437\u0431\u0435\u0440\u0443\u0441\u044C."
  - answerName: "\u043D\u0435\u0442"
    wordsInOrder:
